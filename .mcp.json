{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub - repos, PRs, issues, code"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "description": "Local filesystem access for project files"
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "description": "Persistent memory for cross-session state"
    }
  },
  "defaults": {
    "github": {
      "owner": "",
      "repo": ""
    }
  },
  "_comments": {
    "setup": "Fill in owner and repo after cloning your GitHub repo",
    "required_env": "GITHUB_TOKEN",
    "optional": "Add other MCP servers as needed (vercel, supabase, figma, slack)"
  }
}
